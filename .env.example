# 服务端专用。不要添加 NEXT_PUBLIC_ 前缀，也不要提交真实密钥。
# 生产环境必须替换管理员密码与加密主密钥。
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=请设置至少12位独立强密码
# 生成方式：openssl rand -base64 32
APP_ENCRYPTION_KEY=
DATABASE_PATH=.data/cuancuan.db
DEMO_VERIFY_CODE=888888

# 可选故障兜底。模型配置迁入管理员后台后仍可保留，数据库配置优先。
STEP_API_KEY=
STEP_API_BASE_URL=https://api.stepfun.com/v1
STEP_MODEL=step-3.5-flash-2603
